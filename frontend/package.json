{
  "name": "spotify-library-manager",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "description": "Spotify Library Manager - Full Stack Application",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "generate": "graphql-codegen --config codegen.yml",
    "validate-schema": "node scripts/validate-schema.js",
    "validate-graphql-manual": "node scripts/validate-graphql-manual.js",
    "check-newlines": "node scripts/check-newlines.js",
    "fix-newlines": "node scripts/fix-newlines.js",
    "pre-generate": "yarn validate-schema",
    "generate-safe": "yarn validate-schema && yarn generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:graphql": "node scripts/test-graphql-operations.js",
    "test:graphql-operations": "node scripts/test-graphql-operations.js",
    "test:all": "yarn test:run && yarn test:graphql"
  },
  "dependencies": {
    "@apollo/client": "^4.0.6",
    "@tanstack/react-router": "^1.132.7",
    "@tanstack/react-router-devtools": "^1.132.7",
    "@tanstack/router-core": "^1.132.7",
    "graphql": "^16.8.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rxjs": "^7.8.1",
    "tiny-invariant": "^1.3.3",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@graphql-codegen/cli": "^6.0.0",
    "@graphql-codegen/typed-document-node": "^6.0.0",
    "@graphql-codegen/typescript": "^5.0.0",
    "@graphql-codegen/typescript-operations": "^5.0.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/router-plugin": "^1.132.7",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.17",
    "csstype": "^3.1.3",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.36.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "happy-dom": "^18.0.1",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.8.3",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
