{
  "name": "spotify-library-manager",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "description": "Spotify Library Manager - Full Stack Application",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "generate": "graphql-codegen --config codegen.yml",
    "validate-schema": "node scripts/validate-schema.js",
    "validate-types": "node scripts/validate-types-ci.js",
    "validate-graphql-manual": "node scripts/validate-graphql-manual.js",
    "check-newlines": "node scripts/check-newlines.js",
    "fix-newlines": "node scripts/fix-newlines.js",
    "pre-generate": "yarn validate-schema",
    "generate-safe": "yarn validate-schema && yarn generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:graphql": "node scripts/test-graphql-operations.js",
    "test:graphql-operations": "node scripts/test-graphql-operations.js",
    "test:all": "yarn test:run && yarn test:graphql",
    "validate:comprehensive": "yarn validate-schema && yarn test:graphql-operations"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@tanstack/react-router": "^1.132.7",
    "@tanstack/react-router-devtools": "^1.132.7",
    "@tanstack/router-core": "^1.132.7",
    "graphql": "^16.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tiny-invariant": "^1.3.3",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^8.56.0",
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/typescript": "^4.0.4",
    "@graphql-codegen/typescript-operations": "^4.1.2",
    "@graphql-codegen/typescript-react-apollo": "^4.3.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/router-plugin": "^1.132.7",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^1.3.1",
    "@vitest/ui": "^1.3.1",
    "autoprefixer": "^10.4.17",
    "csstype": "^3.1.3",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.36.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "happy-dom": "^13.3.8",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.8.3",
    "vite": "^5.4.20",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^1.3.1"
  }
}
