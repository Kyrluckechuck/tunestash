# Spotify Library Manager - Environment Variables
# Copy this file to .env and adjust values for your environment.

# Directory on the host to bind to /config in the containers.
# This must be an absolute path.
SLM_CONFIG_DIR=

# Directory on the host where downloaded music is stored (bind-mounted to /mnt/music_spotify)
# Example: /mnt/nas/music_spotify
MUSIC_DIR=

# API settings
DJANGO_SECRET_KEY=django-insecure-development-only-key
DJANGO_DEBUG=True
AUTH_SECRET_KEY=change-me-in-production
DJANGO_DB_PATH=/config/db/db.sqlite3

# Frontend build-time API URL (only used when building the frontend image)
# During docker-compose, the frontend talks to the API via the shared network using path /graphql
VITE_API_URL=/graphql
