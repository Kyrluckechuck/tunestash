# TuneStash - Environment Variables
# Copy this file to .env and adjust values for your environment.

# Docker Images - Update these to use specific tags for your deployment
BACKEND_IMAGE=ghcr.io/kyrluckechuck/tunestash:latest
FRONTEND_IMAGE=ghcr.io/kyrluckechuck/tunestash-frontend:latest

# Development - Override image tag for branch-specific testing (used in docker-compose.override.yml)
# Uncomment to use a specific branch's image instead of 'latest'
# BACKEND_IMAGE_TAG=my-feature-branch

# Directory Paths - Customize for your system
SLM_CONFIG_DIR=/config
MUSIC_DIR=/mnt/music_spotify

# Database Configuration
POSTGRES_DB=tunestash
POSTGRES_USER=slm_user
POSTGRES_PASSWORD=slm_dev_password

# Application Configuration
DJANGO_SECRET_KEY=django-insecure-development-only-key
DJANGO_DEBUG=False
HOST=0.0.0.0
PORT=5000

# Port Mappings
FRONTEND_PORT=3000

# Frontend Configuration
VITE_API_URL=/graphql

# Spotify OAuth Configuration (optional - for private playlist access)
# Get credentials from: https://developer.spotify.com/dashboard
# Create an app and add redirect URI: http://127.0.0.1:5000/auth/spotify/callback
# NOTE: Spotify requires 127.0.0.1 (not localhost) for local development
# The system auto-detects the redirect URI from your browser's request
# SPOTIPY_CLIENT_ID=your_spotify_client_id
# SPOTIPY_CLIENT_SECRET=your_spotify_client_secret
