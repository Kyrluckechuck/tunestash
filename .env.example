# Spotify Library Manager - Environment Variables
# Copy this file to .env and adjust values for your environment.

# Docker Images - Update these to use specific tags for your deployment
BACKEND_IMAGE=ghcr.io/kyrluckechuck/spotify-library-manager:latest
FRONTEND_IMAGE=ghcr.io/kyrluckechuck/spotify-library-manager-frontend:latest

# Directory Paths - Customize for your system
SLM_CONFIG_DIR=/config
MUSIC_DIR=/mnt/music_spotify

# Database Configuration
POSTGRES_DB=spotify_library_manager
POSTGRES_USER=slm_user
POSTGRES_PASSWORD=slm_dev_password

# Application Configuration
DJANGO_SECRET_KEY=django-insecure-development-only-key
DJANGO_DEBUG=False
AUTH_SECRET_KEY=change-me-in-production
HOST=0.0.0.0
PORT=5000

# Port Mappings
WEB_PORT=5000
FRONTEND_PORT=3000

# Frontend Configuration
VITE_API_URL=/graphql
