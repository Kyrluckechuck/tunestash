# TuneStash - Environment Variables
# Copy this file to .env and adjust values for your environment.

# Docker Images - Update these to use specific tags for your deployment
BACKEND_IMAGE=ghcr.io/kyrluckechuck/tunestash:latest
FRONTEND_IMAGE=ghcr.io/kyrluckechuck/tunestash-frontend:latest

# Development - Override image tag for branch-specific testing (used in docker-compose.override.yml)
# Uncomment to use a specific branch's image instead of 'latest'
# BACKEND_IMAGE_TAG=my-feature-branch

# Directory Paths - Customize for your system
SLM_CONFIG_DIR=/config
MUSIC_DIR=/mnt/music_spotify

# Database Configuration
POSTGRES_DB=tunestash
POSTGRES_USER=slm_user
# Set a real value for production. Local Compose development can omit this
# when TUNESTASH_DEV_MODE=true and use the override's development value.
POSTGRES_PASSWORD=replace-with-a-database-password

# Celery Broker (Valkey 8, Redis-protocol compatible)
# Override only if pointing at an external Redis/Valkey deployment.
CELERY_BROKER_URL=redis://valkey:6379/0

# Application Configuration
# Replace this with a unique random value outside local development.
DJANGO_SECRET_KEY=replace-with-a-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
TUNESTASH_DEV_MODE=false
HOST=0.0.0.0
PORT=5000

# Port Mappings
FRONTEND_PORT=3000

# Frontend Configuration
VITE_API_URL=/graphql

# Spotify OAuth Configuration (optional - for private playlist access)
# Get credentials from: https://developer.spotify.com/dashboard
# Create an app and add redirect URI: http://127.0.0.1:5000/auth/spotify/callback
# NOTE: Spotify requires 127.0.0.1 (not localhost) for local development
# The system auto-detects the redirect URI from your browser's request
# SPOTIPY_CLIENT_ID=your_spotify_client_id
# SPOTIPY_CLIENT_SECRET=your_spotify_client_secret

# ============================================
# Queuetip (collaborative playlist app)
# ============================================
# Public URLs for the Queuetip ASGI process and frontend. These build the
# redirect URI sent to Spotify, so the host MUST match a URI registered in
# your Spotify Dev App. Spotify rejects 'localhost' — use 127.0.0.1.
# Required Spotify Redirect URI to whitelist: <QUEUETIP_PUBLIC_URL>/auth/spotify/callback
# In dev, both URLs are the same (Vite proxies /graphql + /auth to the backend).
# QUEUETIP_PUBLIC_URL=http://127.0.0.1:3001
# QUEUETIP_FRONTEND_URL=http://127.0.0.1:3001
# Generate via: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Required in production for encrypting Subsonic connection passwords at rest.
# QUEUETIP_FERNET_KEY=
