#!/usr/bin/env sh

# Incremental pre-commit hook for Spotify Library Manager (tracked in repo)
echo "🔍 Running pre-commit checks (staged files only)..."

# Collect staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

# 1) Trailing newline enforcement (staged files only)
echo "🔧 Ensuring trailing newlines on staged files..."
python scripts/check-repo-newlines.py fix --staged >/dev/null 2>&1 || true
# Re-stage only the files that were modified by the newline fixer
if [ -n "$STAGED_FILES" ]; then
    echo "$STAGED_FILES" | xargs -r git add >/dev/null 2>&1
fi
python scripts/check-repo-newlines.py check --staged >/dev/null 2>&1
if [ $? -ne 0 ]; then
    echo "❌ Newline check failed."
    exit 1
fi

# 2) Frontend: run checks only on changed files
if [ -d "frontend" ]; then
    # Filter for frontend files
    FE_TS_FILES=$(printf "%s\n" "$STAGED_FILES" | grep -E '^frontend/.*\.(ts|tsx)$' || true)
    FE_LINT_FILES=$(printf "%s\n" "$STAGED_FILES" | grep -E '^frontend/.*\.(ts|tsx|js|jsx)$' | sed 's:^frontend/::' | tr '\n' ' ' || true)
    FE_PRETTIER_FILES=$(printf "%s\n" "$STAGED_FILES" | grep -E '^frontend/.*\.(ts|tsx|js|jsx|json|md|css|scss|html)$' | sed 's:^frontend/::' | tr '\n' ' ' || true)

    # Detect GraphQL generated types or query changes
    FE_GQL_TYPES=$(printf "%s\n" "$STAGED_FILES" | grep -E '^frontend/src/types/generated/graphql\.ts$' || true)
    FE_GQL_QUERIES=$(printf "%s\n" "$STAGED_FILES" | grep -E '^frontend/src/queries/.*\.(ts|graphql)$' || true)

    if [ -n "$FE_TS_FILES" ] || [ -n "$FE_LINT_FILES" ] || [ -n "$FE_PRETTIER_FILES" ] || [ -n "$FE_GQL_TYPES" ] || [ -n "$FE_GQL_QUERIES" ]; then
        echo "🔧 Running frontend checks on staged files..."
        (
            cd frontend || exit 1
            # GraphQL generated types validation when queries/types changed
            if [ -n "$FE_GQL_TYPES" ] || [ -n "$FE_GQL_QUERIES" ]; then
                echo "🔎 GraphQL generated types validation..."
                yarn -s validate-types >/dev/null 2>&1 || { echo "❌ GraphQL types validation failed."; exit 1; }
            fi
            # TypeScript type check only if TS files changed
            if [ -n "$FE_TS_FILES" ]; then
                echo "📝 TypeScript type check (full project)..."
                yarn -s tsc --noEmit --project tsconfig.app.json || {
                    echo "❌ TypeScript type check failed."; exit 1; }
            fi
            
            # Autofix on staged files first
            if [ -n "$FE_LINT_FILES" ]; then
                echo "🛠️  ESLint auto-fix (changed files)..."
                # shellcheck disable=SC2086
                ESLINT_USE_FLAT_CONFIG=true yarn -s eslint --fix $FE_LINT_FILES >/dev/null 2>&1 || true
            fi
            if [ -n "$FE_PRETTIER_FILES" ]; then
                echo "🖌️  Prettier write (changed files)..."
                # shellcheck disable=SC2086
                yarn -s prettier --write $FE_PRETTIER_FILES >/dev/null 2>&1 || true
            fi
            
            # Re-stage any changes produced by autofixers (frontend files only)
            if [ -n "$FE_LINT_FILES" ] || [ -n "$FE_PRETTIER_FILES" ]; then
                # shellcheck disable=SC2086
                git add $FE_LINT_FILES $FE_PRETTIER_FILES >/dev/null 2>&1 || true
            fi

            # ESLint on changed JS/TS files (strict)
            if [ -n "$FE_LINT_FILES" ]; then
                echo "🔧 ESLint check (changed files)..."
                # shellcheck disable=SC2086
                ESLINT_USE_FLAT_CONFIG=true yarn -s eslint --no-warn-ignored --max-warnings=0 $FE_LINT_FILES || {
                    echo "❌ ESLint check failed."; exit 1; }
            fi
            # Prettier check on changed format-able files (strict)
            if [ -n "$FE_PRETTIER_FILES" ]; then
                echo "🎨 Prettier check (changed files)..."
                # shellcheck disable=SC2086
                yarn -s prettier --check $FE_PRETTIER_FILES >/dev/null 2>&1 || {
                    echo "❌ Prettier format check failed."; exit 1; }
            fi
        ) || exit 1
    fi
fi

# 3) Backend: Python autofix and lint on changed files
if [ -d "api" ]; then
    PY_CHANGED=$(printf "%s\n" "$STAGED_FILES" | grep -E '^api/.*\.py$' | sed 's:^api/::' | tr '\n' ' ' || true)
    if [ -n "$PY_CHANGED" ]; then
        echo "🛠️  Running Python autofixers on changed files..."
        (
            cd api || exit 1
            # Auto-format with isort and black (best-effort)
            # shellcheck disable=SC2086
            python -m isort $PY_CHANGED >/dev/null 2>&1 || true
            # shellcheck disable=SC2086
            python -m black $PY_CHANGED >/dev/null 2>&1 || true
            # Re-stage only the auto-fixed Python files
            if [ -n "$PY_CHANGED" ]; then
                # shellcheck disable=SC2086
                git add $PY_CHANGED >/dev/null 2>&1 || true
            fi
            echo "🔍 Running Python linting on changed files..."
            # shellcheck disable=SC2086
            python -m flake8 --extend-ignore=W503 --exclude=.venv,__pycache__,node_modules $PY_CHANGED >/dev/null 2>&1 || {
                echo "❌ Python linting failed."; exit 1; }
        ) || exit 1
    fi
fi

echo "✅ All staged-file checks passed!"
echo "💡 Note: CI runs comprehensive checks; pre-commit is incremental."
