default:
  # Downloader defaults (used by api/lib/config_class.py)
  # YouTube Music cookies for spotdl downloads
  # - Without YTM Premium: 128kbps AAC
  # - With YTM Premium cookies: 256kbps AAC
  youtube_cookies_location: "/config/youtube_music_cookies.txt"

  # Spotify OAuth Configuration (for private playlist access)
  # When enabled, provides web-based OAuth flow for user authentication
  spotify_user_auth_enabled: false
  # OAuth redirect URI - must match Spotify app settings
  # NOTE: Spotify requires explicit IP (127.0.0.1) instead of 'localhost'
  # The system automatically detects the host from the request, but you can set a default here
  # For local dev: http://127.0.0.1:5000/auth/spotify/callback
  # For production: https://yourdomain.com/auth/spotify/callback
  spotify_redirect_uri: "http://127.0.0.1:5000/auth/spotify/callback"

  # Spotify Developer App Credentials (REQUIRED for OAuth)
  # Create an app at: https://developer.spotify.com/dashboard
  # Add the redirect URI above to your app's settings
  # SPOTIPY_CLIENT_ID and SPOTIPY_CLIENT_SECRET can also be set via environment variables
  SPOTIPY_CLIENT_ID: ""
  SPOTIPY_CLIENT_SECRET: ""

  po_token: null
  log_level: "INFO"
  # Enable verbose diagnostic logging for worker crashes and performance issues
  # Set to true for development/debugging, false for production (reduces log noise)
  worker_diagnostics_enabled: true
  no_lrc: false
  overwrite: false

  # Download provider configuration
  # Specify which providers to try and in what order
  # Available providers: spotdl (YouTube Music), tidal, qobuz
  # - spotdl: Most reliable, requires YTM cookies, 128-256kbps
  # - tidal/qobuz: Higher quality (up to FLAC), but use third-party APIs (squid.wtf)
  #   which may be less reliable or have downtime
  # Default: Try all providers in order for maximum success rate
  download_provider_order:
    - spotdl
    - tidal
    - qobuz

  # Fallback provider quality preference (applies to Tidal and Qobuz)
  # - high: 320kbps AAC (M4A) - default, consistent with spotdl output
  # - lossless: FLAC 16-bit 44.1kHz (larger files, kept as FLAC)
  # - hi_res: FLAC 24-bit (when available, kept as FLAC)
  fallback_quality: "high"

  # Qobuz format preference for HIGH quality
  # When false (default): Downloads FLAC and converts to M4A/AAC for library consistency
  # When true: Downloads MP3 320kbps directly (no conversion, slightly larger files)
  qobuz_use_mp3: false

  # Album selection
  ALBUM_TYPES_TO_DOWNLOAD:
    - single
    - album
    - compilation
  ALBUM_GROUPS_TO_IGNORE:
    - appears_on

  # Operational toggles
  disable_missing_tracked_artist_download: false

  # Notifications (Apprise) - alerts for credential expiry and high error rates
  # See: https://github.com/caronc/apprise/wiki#notification-services
  NOTIFICATIONS_ENABLED: false
  NOTIFICATIONS_URLS: []
    # Examples:
    # - "discord://webhook_id/webhook_token"
    # - "tgram://bot_token/chat_id"
    # - "ntfy://ntfy.sh/my-topic"
    # - "gotify://hostname/token"
  NOTIFICATIONS_COOLDOWN_MINUTES: 60
  NOTIFICATIONS_ERROR_THRESHOLD: 10
  NOTIFICATIONS_ERROR_WINDOW_HOURS: 6
  # Cookie expiration warnings (days before expiry)
  # - WARN: First warning (default 7 days) - "Consider refreshing soon"
  # - URGENT: Urgent warning (default 1 day) - "Expiring soon!"
  NOTIFICATIONS_COOKIE_WARN_DAYS: 7
  NOTIFICATIONS_COOKIE_URGENT_DAYS: 1
  # Optional: Name shown in notification titles (e.g. "MyServer: Cookies Expired")
  # Defaults to "TuneStash" if not set
  NOTIFICATIONS_INSTANCE_NAME: ""

  # External Music Lists (Last.fm, ListenBrainz)
  # Last.fm API key - free, get one at https://www.last.fm/api/account/create
  LASTFM_API_KEY: ""
  # ListenBrainz user token (optional, for private listening data)
  # Get yours at https://listenbrainz.org/settings/
  LISTENBRAINZ_USER_TOKEN: ""

  # Optional: paths (ensure these exist in your environment)
  final_path: "/mnt/music_spotify"
